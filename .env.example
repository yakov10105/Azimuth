# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_in_prod
NEO4J_URI=bolt://localhost:7687

# Qdrant
QDRANT_URL=http://localhost:6333

# PostgreSQL
POSTGRES_USER=azimuth
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=azimuth
POSTGRES_DSN=postgresql://azimuth:changeme_in_prod@localhost:5432/azimuth

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Application
LOG_LEVEL=info                 # debug | info | warn | error
TARGET_REPO_PATH=              # path to the repository to ingest
LLM_MODEL=claude-sonnet-4-6
GRAPH_WALKER_DEPTH=3
WORKER_POOL_SIZE=8
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_BATCH_SIZE=100
NEO4J_WRITE_BATCH_SIZE=500
